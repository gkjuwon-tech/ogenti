# ──────────────────────────────────────────────────────────────────────────
# Ogenti Studio — local environment template
# ──────────────────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in the values you need. The app
# starts in "demo mode" without any of these — Stripe billing is mocked and
# magic-link auth falls back to a dev-only credentials provider that signs in
# any email address.
#
# Only the variables in the REQUIRED section need to be set for the app to
# boot. The rest enable real integrations.

# ── REQUIRED ──────────────────────────────────────────────────────────────

# Where Prisma writes the SQLite database for local development. Switch to
# postgresql://… in production.
DATABASE_URL="file:./dev.db"

# Random 32-byte secret for NextAuth session JWTs.
#   openssl rand -base64 32
AUTH_SECRET="replace-me-with-openssl-rand"

# Public URL the app is reachable at. Used by Stripe redirect URLs and email
# templates. Override per environment.
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── AUTH (magic-link email; optional in dev) ──────────────────────────────

# Resend API key for the email magic-link provider. When unset the dev-login
# credentials provider is enabled instead (any email signs in).
# AUTH_RESEND_KEY="re_xxx"
# AUTH_EMAIL_FROM="Ogenti Studio <login@ogenti.dev>"

# ── STRIPE (billing; optional in dev) ─────────────────────────────────────

# Server-side API key. Without this the billing routes fall back to demo
# mode and never call Stripe.
# STRIPE_SECRET_KEY="sk_test_xxx"

# Webhook signing secret for /api/billing/webhook.
# STRIPE_WEBHOOK_SECRET="whsec_xxx"

# Price IDs, populated by `pnpm tsx scripts/setup-stripe.ts` (see README).
# STRIPE_PRICE_STARTER="price_xxx"
# STRIPE_PRICE_STUDIO="price_xxx"
# STRIPE_PRICE_AGENCY="price_xxx"
# STRIPE_PRICE_PAYG_METERED="price_xxx"
# STRIPE_PRICE_OVERAGE_METERED="price_xxx"

# ── OGENTI INFERENCE (real model; optional in dev) ─────────────────────────

# When set, the studio talks to the Ogenti inference server (the FastAPI
# wrapper around the retrofit DiT model) instead of the MockOgentiClient.
# OGENTI_INFERENCE_URL="https://inference.ogenti.dev"
# OGENTI_INFERENCE_TOKEN="ogt_live_xxx"
